<div class="max-w-md mx-auto mt-16">
  <div class="card-modern-static">
    <div class="card-body text-center">
      <div class="text-5xl mb-4">🏀</div>
      <h2 class="card-title justify-center text-2xl mb-2"><%= t('club_joins.show.title') %></h2>
      <p class="text-base-content/70 mb-6">
        <%= t('club_joins.show.invited_to', club_name: content_tag(:span, @club.name, class: "font-bold text-primary")).html_safe %>
      </p>

      <div class="divider"></div>

      <div class="text-sm text-base-content/60 mb-6">
        <% if @club.description.present? %>
          <p><%= @club.description %></p>
        <% end %>
        <p class="mt-2"><%= t('club_joins.show.member_count', count: @club.club_memberships.count) %></p>
      </div>

      <%= button_to t('club_joins.show.join_button'), club_join_path(@invitation.code), method: :post, class: "btn btn-primary btn-lg w-full" %>

      <div class="mt-4">
        <%= link_to t('club_joins.show.back_to_home'), clubs_path, class: "btn btn-ghost btn-sm" %>
      </div>
    </div>
  </div>
</div>
