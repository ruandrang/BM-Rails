<div class="max-w-4xl mx-auto">
  <!-- 뒤로가기 -->
  <div class="mb-4">
    <%= link_to club_path(@club), class: "btn btn-ghost btn-sm gap-2" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <%= t('common.back') %>
    <% end %>
  </div>

  <!-- 페이지 헤더 -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="page-title text-base-content mb-2"><%= t('club_memberships.index.title') %></h1>
      <p class="text-base-content/60"><%= t('club_memberships.index.subtitle', club_name: @club.name) %></p>
    </div>
    <% if @current_membership&.admin? %>
      <%= link_to club_invitations_path(@club), class: "btn btn-primary btn-sm gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <%= t('club_memberships.index.invite_code') %>
      <% end %>
    <% end %>
  </div>

  <!-- 멤버 목록 -->
  <div class="space-y-3">
    <% @memberships.each do |membership| %>
      <div class="card-modern-static">
        <div class="card-body p-4 flex-row items-center justify-between">
          <div class="flex items-center gap-3">
            <!-- 역할 아이콘 -->
            <% if membership.owner? %>
              <span class="text-xl">👑</span>
            <% elsif membership.role == "admin" %>
              <span class="text-xl">🛡️</span>
            <% elsif membership.role == "manager" %>
              <span class="text-xl">📋</span>
            <% else %>
              <span class="text-xl">👤</span>
            <% end %>

            <div>
              <div class="font-bold">
                <%= membership.user.display_name %>
                <% if membership.user == current_user %>
                  <span class="text-xs text-base-content/50"><%= t('club_memberships.index.me') %></span>
                <% end %>
              </div>
              <div class="text-xs text-base-content/50">
                <% case membership.role %>
                <% when "owner" %>
                  <span class="badge badge-warning badge-xs"><%= t('club_memberships.index.roles.owner') %></span>
                <% when "admin" %>
                  <span class="badge badge-info badge-xs"><%= t('club_memberships.index.roles.admin') %></span>
                <% when "manager" %>
                  <span class="badge badge-success badge-xs"><%= t('club_memberships.index.roles.manager') %></span>
                <% when "member" %>
                  <span class="badge badge-ghost badge-xs"><%= t('club_memberships.index.roles.member') %></span>
                <% end %>
                <% if membership.joined_at %>
                  · <%= t('club_memberships.index.joined_at') %> <%= membership.joined_at.strftime('%Y.%m.%d') %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- 액션 버튼 -->
          <div class="flex items-center gap-2 flex-wrap">
            <%# owner: 모든 역할 변경 가능 %>
            <% if @current_membership&.owner? && membership.user != current_user && !membership.owner? %>
              <% case membership.role %>
              <% when "admin" %>
                <%= button_to t('club_memberships.index.actions.change_to_manager'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "manager" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
                <%= button_to t('club_memberships.index.actions.change_to_member'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "member" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
              <% when "manager" %>
                <%= button_to t('club_memberships.index.actions.promote_to_admin'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "admin" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
                <%= button_to t('club_memberships.index.actions.change_to_member'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "member" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
              <% when "member" %>
                <%= button_to t('club_memberships.index.actions.promote_to_admin'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "admin" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
                <%= button_to t('club_memberships.index.actions.promote_to_manager'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "manager" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
              <% end %>

              <!-- 소유권 양도 -->
              <%= button_to t('club_memberships.index.actions.transfer_ownership'),
                  transfer_ownership_club_memberships_path(@club),
                  params: { membership_id: membership.id },
                  method: :patch,
                  form: { onsubmit: "return confirm('#{j t('club_memberships.index.confirms.transfer_ownership')}');" },
                  class: "btn btn-ghost btn-xs text-warning" %>

            <%# admin: manager/member만 변경 가능 %>
            <% elsif @current_membership&.admin? && !@current_membership&.owner? && membership.user != current_user && !membership.admin? %>
              <% if membership.role == "manager" %>
                <%= button_to t('club_memberships.index.actions.change_to_member'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "member" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
              <% elsif membership.role == "member" %>
                <%= button_to t('club_memberships.index.actions.promote_to_manager'),
                    update_role_club_membership_path(@club, membership),
                    params: { role: "manager" },
                    method: :patch,
                    class: "btn btn-ghost btn-xs" %>
              <% end %>
            <% end %>

            <!-- 추방/탈퇴 -->
            <% if membership.user == current_user && !membership.owner? %>
              <%= button_to t('club_memberships.index.actions.leave'),
                  club_membership_path(@club, membership),
                  method: :delete,
                  form: { onsubmit: "return confirm('#{j t('club_memberships.index.confirms.leave_club')}');" },
                  class: "btn btn-ghost btn-xs text-error" %>
            <% elsif @current_membership&.admin? && membership.user != current_user && !membership.owner? %>
              <%= button_to t('club_memberships.index.actions.remove'),
                  club_membership_path(@club, membership),
                  method: :delete,
                  form: { onsubmit: "return confirm('#{j t('club_memberships.index.confirms.remove_member')}');" },
                  class: "btn btn-ghost btn-xs text-error" %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
