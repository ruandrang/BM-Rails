<% content_for :title, t("guide.page_title") %>

<div class="max-w-5xl mx-auto">
  <div class="mb-6">
    <h1 class="page-title text-base-content mb-2"><%= t("guide.page_title") %></h1>
    <p class="text-base-content/60"><%= t("guide.page_subtitle") %></p>
  </div>

  <div class="alert alert-warning mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
    <div>
      <p class="font-semibold"><%= t("guide.beta_warning_title") %></p>
      <p class="text-sm"><%= t("guide.beta_warning_desc") %></p>
    </div>
  </div>

  <div class="card-modern-static">
    <div class="card-body p-6 md:p-8 space-y-6">

      <!-- 1. 클럽 관리 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-primary/10 text-primary rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">🏀</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.club.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.club.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.club.create_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.club.create_desc").html_safe %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.club.edit_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.club.edit_desc").html_safe %></p>
          </div>
        </div>
      </section>

      <!-- 2. 선수 관리 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-secondary/10 text-secondary rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">👥</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.member.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.member.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.member.register_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.member.register_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.member.csv_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.member.csv_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.member.reorder_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.member.reorder_desc") %></p>
          </div>
        </div>
      </section>

      <!-- 3. 경기 & 팀 배정 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-accent/10 text-accent rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">🏆</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.match.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.match.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.match.create_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.match.create_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.match.auto_assign_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.match.auto_assign_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.match.reassign_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.match.reassign_desc").html_safe %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.match.three_team_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.match.three_team_desc") %></p>
          </div>
        </div>
      </section>

      <!-- 4. 스코어보드 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-info/10 text-info rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">📺</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.scoreboard.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.scoreboard.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.scoreboard.connected_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.scoreboard.connected_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.scoreboard.standalone_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.scoreboard.standalone_desc").html_safe %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.scoreboard.features_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.scoreboard.features_desc") %></p>
          </div>
        </div>
      </section>

      <!-- 5. 통계 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-success/10 text-success rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">📊</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.stats.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.stats.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.stats.player_stats_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.stats.player_stats_desc").html_safe %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.stats.share_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.stats.share_desc") %></p>
          </div>
        </div>
      </section>

      <!-- 6. 멤버십 & 초대 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-warning/10 text-warning rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">🤝</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.membership.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.membership.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-2"><%= t("guide.sections.membership.roles_title") %></p>
            <div class="flex flex-wrap gap-2">
              <div class="badge badge-primary gap-1"><%= t("guide.sections.membership.role_owner") %> <span class="opacity-70">· <%= t("guide.sections.membership.role_owner_desc") %></span></div>
              <div class="badge badge-secondary gap-1"><%= t("guide.sections.membership.role_admin") %> <span class="opacity-70">· <%= t("guide.sections.membership.role_admin_desc") %></span></div>
              <div class="badge gap-1"><%= t("guide.sections.membership.role_member") %> <span class="opacity-70">· <%= t("guide.sections.membership.role_member_desc") %></span></div>
            </div>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.membership.invite_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.membership.invite_desc") %></p>
          </div>
        </div>
      </section>

      <!-- 7. 데이터 백업 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-error/10 text-error rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">💾</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.backup.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.backup.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.backup.export_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.backup.export_desc").html_safe %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.backup.import_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.backup.import_desc") %></p>
          </div>
        </div>
      </section>

      <!-- 8. 설정 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-neutral/10 text-neutral rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">⚙️</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.settings.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.settings.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.settings.profile_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.settings.profile_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.settings.game_time_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.settings.game_time_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.settings.voice_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.settings.voice_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.settings.language_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.settings.language_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.settings.possession_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.settings.possession_desc") %></p>
          </div>
        </div>
      </section>

      <!-- 9. 로그인 -->
      <section class="rounded-2xl border border-base-300 bg-base-100 p-5 md:p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-primary/10 text-primary rounded-xl w-12 h-12 flex items-center justify-center text-2xl shrink-0">🔐</div>
          <div>
            <h2 class="text-xl font-bold text-base-content"><%= t("guide.sections.login.title") %></h2>
            <p class="text-base-content/50 text-sm"><%= t("guide.sections.login.subtitle") %></p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.login.social_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.login.social_desc") %></p>
          </div>
          <div class="rounded-xl bg-base-200/40 p-4">
            <p class="font-semibold text-base-content mb-1"><%= t("guide.sections.login.email_title") %></p>
            <p class="text-sm text-base-content/70"><%= t("guide.sections.login.email_desc") %></p>
          </div>
        </div>
      </section>

    </div>
  </div>

  <div class="mt-6 text-center text-base-content/40 text-sm">
    ver. 0.3 Beta
  </div>
</div>
