<div class="max-w-4xl mx-auto">
  <!-- 뒤로가기 -->
  <div class="mb-4">
    <%= link_to club_path(@club), class: "btn btn-ghost btn-sm gap-2" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <%= t('common.back') %>
    <% end %>
  </div>

  <!-- 페이지 헤더 -->
  <div class="mb-8">
    <h1 class="page-title text-base-content mb-2"><%= t('club_invitations.index.title') %></h1>
    <p class="text-base-content/60"><%= t('club_invitations.index.subtitle', club_name: @club.name) %></p>
  </div>

  <!-- 초대 코드 생성 폼 (admin 이상) -->
  <% if @current_membership&.admin? %>
    <div class="card-modern-static mb-8">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4"><%= t('club_invitations.index.new_code') %></h2>
        <%= form_with model: [@club, ClubInvitation.new], url: club_invitations_path(@club), local: true, class: "flex flex-wrap items-end gap-4" do |f| %>
          <div class="form-control">
            <label class="label"><span class="label-text"><%= t('club_invitations.index.expires_at') %></span></label>
            <%= f.datetime_local_field :expires_at, class: "input input-bordered input-sm" %>
          </div>
          <div class="form-control">
            <label class="label"><span class="label-text"><%= t('club_invitations.index.max_uses') %></span></label>
            <%= f.number_field :max_uses, min: 1, placeholder: t('club_invitations.index.max_uses_placeholder'), class: "input input-bordered input-sm w-32" %>
          </div>
          <button type="submit" class="btn btn-primary btn-sm"><%= t('club_invitations.index.create_button') %></button>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 초대 코드 목록 -->
  <% if @invitations.any? %>
    <div class="space-y-4">
      <% @invitations.each do |invitation| %>
        <div class="card-modern-static">
          <div class="card-body p-4 flex-row items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="font-mono text-xl font-bold tracking-wider text-primary"><%= invitation.code %></div>
              <div class="text-sm text-base-content/60">
                <% if invitation.expired? %>
                  <span class="badge badge-error badge-sm"><%= t('club_invitations.index.status.expired') %></span>
                <% elsif invitation.max_uses_reached? %>
                  <span class="badge badge-warning badge-sm"><%= t('club_invitations.index.status.max_uses_reached') %></span>
                <% else %>
                  <span class="badge badge-success badge-sm"><%= t('club_invitations.index.status.active') %></span>
                <% end %>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="text-xs text-base-content/50 text-right">
                <div><%= t('club_invitations.index.usage') %> <%= invitation.use_count %><%= "/#{invitation.max_uses}" if invitation.max_uses %></div>
                <% if invitation.expires_at %>
                  <div><%= t('club_invitations.index.expires') %> <%= l(invitation.expires_at, format: :short) rescue invitation.expires_at.strftime('%m/%d %H:%M') %></div>
                <% else %>
                  <div><%= t('club_invitations.index.expires') %> <%= t('club_invitations.index.no_expiry') %></div>
                <% end %>
              </div>

              <% if @current_membership&.admin? %>
                <button type="button"
                  class="btn btn-ghost btn-sm"
                  onclick="navigator.clipboard.writeText('<%= club_join_url(invitation.code) %>').then(() => alert('<%= j t('club_invitations.index.link_copied') %>'))">
                  <%= t('club_invitations.index.copy') %>
                </button>
                <%= button_to club_invitation_path(@club, invitation),
                    method: :delete,
                    form: { onsubmit: "return confirm('#{j t('club_invitations.index.delete_confirm')}');" },
                    class: "btn btn-ghost btn-sm text-error" do %>
                  <%= t('club_invitations.index.delete') %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-icon">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
      </div>
      <p class="empty-state-description"><%= t('club_invitations.index.empty') %></p>
    </div>
  <% end %>
</div>
